<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - AMS</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="login-page">
    <div class="login-panel">
        <div class="login-hero">
            <div class="brand-badge">AMS</div>
            <h2>Attendance Management System</h2>
            <p>Monitor attendance, manage schedules, and keep your school records in one place.</p>
            <ul class="login-hero-list">
                <li>Real-time class tracking</li>
                <li>Easy QR-based attendance</li>
                <li>Reliable reporting for staff</li>
            </ul>
        </div>
        <div class="login-card">
            <div>
                <span class="login-kicker">Welcome back</span>
                <h1>Sign in</h1>
            </div>

            
            

            <form action="/login" method="post">
                <div class="form-group">
                    <label for="username">Username</label>
                    <input type="text" id="username" name="username" class="form-control" required autofocus>
                </div>
                <div class="form-group">
                    <label for="password">Password</label>
                    <input type="password" id="password" name="password" class="form-control" required>
                </div>
                <button type="submit" class="btn btn-primary login-btn">Login</button>
            </form>
            <p class="login-footer-text">
                <a href="/forgot-password">Forgot Password?</a>
            </p>
        </div>
    </div>
</div>
</body>
</html>
