spring.mail.username=${MAIL_USERNAME:b20400001@smtp-brevo.com}
spring.mail.password=${MAIL_PASSWORD:${BREVO_SMTP_PASSWORD:}}
central.mail.from-name=LU Centralized System
central.mail.from-email=edulibrary67@gmail.com
