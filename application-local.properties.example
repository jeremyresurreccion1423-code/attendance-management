# --- Supabase Database ---
spring.datasource.url=jdbc:postgresql://aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require
spring.datasource.username=postgres.YOUR_PROJECT_REF
spring.datasource.password=your-database-password

# --- LU Centralized System — Brevo SMTP (same as Library) ---
