# Copy to: src/main/resources/application-local.properties
# (that file is gitignored — never commit secrets)

# --- Supabase Database ---
spring.datasource.url=jdbc:postgresql://aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require
spring.datasource.username=postgres.YOUR_PROJECT_REF
spring.datasource.password=your-database-password

# --- LU Centralized System — Brevo (HTTPS preferred; SMTP fallback) ---
# Railway: set BREVO_API_KEY (required on Hobby). Optional SMTP: MAIL_PASSWORD / BREVO_SMTP_PASSWORD
spring.mail.username=${MAIL_USERNAME:b20400001@smtp-brevo.com}
spring.mail.password=${MAIL_PASSWORD:${BREVO_SMTP_PASSWORD:}}
central.mail.brevo-api-key=${BREVO_API_KEY:}
central.mail.from-name=LU Centralized System
central.mail.from-email=edulibrary67@gmail.com
